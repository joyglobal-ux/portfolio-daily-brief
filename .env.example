# Copy to .env for local development. NEVER commit .env.
# In GitHub Actions, these are set via repo Secrets.

# Google Sheets published CSV URL (보안: 게시 URL이므로 read-only)
GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/e/.../pub?gid=750100795&single=true&output=csv

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: DART OpenAPI key (https://opendart.fss.or.kr/)
# 등록 시 한국 공시 RSS 직접 조회 가능. 미등록 시 Google News RSS만 사용.
DART_API_KEY=
